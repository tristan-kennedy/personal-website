---
import { getPosts } from "../../lib/content/posts";

const posts = await getPosts();
const featured = posts.slice(0, 1);
---

<section id="posts" class="section-shell section-grid">
  <h2 data-animate class="mb-4 hidden md:col-start-1 md:col-end-2 md:block">
    [03]
  </h2>
  <h1
    data-animate
    class="display-xl mb-4 md:col-start-5 md:col-end-11 md:text-right"
  >
    Latest Thought
  </h1>
  <a
    data-animate
    href="/posts"
    class="h2 transition-colors transition-transform hover:-translate-x-2 hover:text-accent md:col-span-full md:mb-32 md:text-right"
    >← ALL POSTS</a
  >
  <div
    data-animate
    class="grid grid-cols-1 gap-8 md:col-start-2 md:col-end-11 md:grid-cols-10 md:gap-x-6"
  >
    <div class="md:col-start-1 md:col-end-8">
      {
        featured.map((featured) => (
          <a href={featured.url} class="group block border border-transparent">
            <div class="flex flex-col gap-y-6">
              <h2 class="uppercase">{featured.data.date}</h2>
              <h3 class="transition-colors group-hover:text-accent">
                {featured.data.title}
              </h3>
              <p class="max-w-prose">
                {featured.data.description.split(".")[0]}...
              </p>
              <h2 class="uppercase transition-colors transition-transform group-hover:translate-x-2 group-hover:text-accent">
                {featured.data.length} →
              </h2>
            </div>
          </a>
        ))
      }
    </div>
    <h2
      data-animate
      class="hidden md:col-start-9 md:col-end-11 md:block md:text-right"
    >
      FEATURED
    </h2>
  </div>
</section>
