---
import Layout from "../../layouts/Layout.astro";
import Menu from "../../components/menu/Menu";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { getPosts } from "../../lib/content/posts";
import ScrollToTop from "../../components/menu/ScrollToTop";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <ScrollToTop client:load />
  <section class="section-grid mb-16 py-8">
    <div class="mb-16 flex items-center justify-between gap-4 md:col-span-full">
      <a
        class="h2 whitespace-nowrap transition-colors transition-transform md:hover:-translate-x-2 md:hover:text-accent"
        href="/posts">← POSTS</a
      >
      <header class="shrink-0">
        <Menu client:load />
      </header>
    </div>
    <div
      class="grid grid-cols-1 gap-y-6 md:col-span-full md:grid-cols-10 md:gap-x-6 md:gap-y-8"
    >
      <h1 class="display-xl md:col-start-1 md:col-end-7">{post.data.title}</h1>
      <p class="max-w-prose md:col-start-1 md:col-end-7">
        {post.data.description}
      </p>
      <div
        class="flex flex-col gap-y-4 md:col-start-8 md:col-end-11 md:row-start-1 md:row-end-3 md:items-end md:self-start md:text-right"
      >
        <div>
          <h2>DATE</h2>
          <p>{post.data.date}</p>
        </div>
        <div>
          <h2>LENGTH</h2>
          <p>{post.data.length}</p>
        </div>
      </div>
      <div class="overflow-hidden md:col-span-full">
        <Image
          src={post.data.image}
          alt={`${post.data.title} cover`}
          class="h-[clamp(24rem,55vw,42rem)] w-full object-cover"
        />
      </div>
    </div>
  </section>
  <article class="mdx pb-16 md:pb-24">
    <Content />
  </article>
  <Footer />
</Layout>
