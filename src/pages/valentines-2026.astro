---
import "../global.css";
import ValentineEnvelope from "../components/ValentineEnvelope";

const title = "Valentines 2026";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="valentine-body">
    <main class="valentine-page">
      <ValentineEnvelope client:only="react" />
    </main>
  </body>
</html>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&display=swap");

  :global(.valentine-body) {
    margin: 0;
    min-height: 100vh;
    overflow: hidden;
    background: linear-gradient(160deg, #b11828, #3b0a12 70%);
    color: var(--color-white);
    font-family: var(--font-inter);
  }

  .valentine-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 0;
  }

  :global(.valentine-envelope) {
    position: relative;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    display: grid;
    place-items: center;
    touch-action: none;
    perspective: 1200px;
    overflow: hidden;
  }

  :global(.valentine-envelope-shell) {
    position: absolute;
    top: 0;
    left: 0;
    transform-origin: center;
    transform-style: preserve-3d;
    cursor: grab;
    will-change: transform;
    user-select: none;
  }

  :global(.valentine-envelope-shell.is-dragging) {
    cursor: grabbing;
    filter: drop-shadow(0 20px 35px rgba(0, 0, 0, 0.25));
  }

  :global(.valentine-envelope-body) {
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: linear-gradient(160deg, #faeeee, #e7c7c7 75%);
    box-shadow:
      0 30px 70px rgba(0, 0, 0, 0.28),
      inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    overflow: hidden;
  }

  :global(.valentine-envelope-body::after) {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 22px;
    background: radial-gradient(
      circle at 50% 15%,
      rgba(255, 255, 255, 0.5),
      transparent 60%
    );
    pointer-events: none;
  }

  :global(.valentine-envelope-back) {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #fff4f4, #ead0d0 70%);
  }

  :global(.valentine-envelope-front) {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, #f2dada, #e4c1c1 70%);
    clip-path: polygon(0 0, 50% 64%, 100% 0, 100% 100%, 0 100%);
  }

  :global(.valentine-envelope-shell.is-open)
    :global(.valentine-envelope-front) {
    clip-path: polygon(0 18%, 50% 70%, 100% 18%, 100% 100%, 0 100%);
  }

  :global(.valentine-seal) {
    position: absolute;
    top: 52%;
    left: 50%;
    width: clamp(72px, 8vw, 92px);
    height: clamp(72px, 8vw, 92px);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle at 35% 30%,
      #ffb1c1,
      #d62828 55%,
      #971f2a 100%
    );
    box-shadow:
      0 16px 28px rgba(0, 0, 0, 0.28),
      inset 0 0 10px rgba(255, 255, 255, 0.35);
    cursor: pointer;
    z-index: 4;
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.6rem;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  :global(.valentine-seal::before) {
    content: "";
    position: absolute;
    inset: 10% 14% 16% 14%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 35%,
      rgba(255, 255, 255, 0.55),
      rgba(0, 0, 0, 0.2)
    );
    opacity: 0.6;
    pointer-events: none;
  }

  :global(.valentine-seal-text) {
    pointer-events: none;
    position: relative;
    z-index: 1;
  }

  :global(.valentine-envelope-shell.is-open) :global(.valentine-seal) {
    transform: translate(-50%, -50%) scale(0.6) rotate(8deg);
    opacity: 0;
    pointer-events: none;
  }

  :global(.valentine-note) {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transform: translate(-999px, -999px);
    transition: opacity 0.35s ease;
    pointer-events: none;
    cursor: grab;
    will-change: transform;
    user-select: none;
    touch-action: none;
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(43, 20, 22, 0.05) 0px,
        rgba(43, 20, 22, 0.05) 1px,
        transparent 1px,
        transparent 30px
      ),
      linear-gradient(160deg, #fffdf9, #f3e7df 80%);
    color: #2b1416;
    padding: 2.1rem 2.3rem 2.3rem;
    border-radius: 12px;
    text-align: left;
    font-family: "Caveat", "Bradley Hand", cursive;
    font-size: clamp(1.35rem, 2.8vw, 1.9rem);
    line-height: 1.45;
    letter-spacing: 0.02em;
    font-style: normal;
    font-weight: 500;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.24);
  }

  :global(.valentine-note.is-visible) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.valentine-note.is-dragging) {
    cursor: grabbing;
  }

  :global(.valentine-note p) {
    margin: 0;
  }

  :global(.valentine-note p + p) {
    margin-top: 0.7rem;
  }

  :global(.valentine-note-actions) {
    margin-top: 1.6rem;
    display: flex;
    gap: 1.6rem;
    align-items: center;
  }

  :global(.valentine-note-yes),
  :global(.valentine-note-no) {
    position: relative;
    border: none;
    padding: 0.2rem 0.6rem;
    background: transparent;
    font-family: "Caveat", "Bradley Hand", cursive;
    font-size: clamp(1.1rem, 2.4vw, 1.5rem);
    letter-spacing: 0.04em;
    text-transform: none;
    font-style: normal;
    color: #2b1416;
    cursor: pointer;
    isolation: isolate;
  }

  :global(.valentine-note-yes)::before,
  :global(.valentine-note-no)::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    transform: translate(-50%, -50%) scale(0.75);
    opacity: 0;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
    z-index: -1;
    pointer-events: none;
  }

  :global(.valentine-note-yes)::before {
    background: rgba(214, 40, 40, 0.18);
  }

  :global(.valentine-note-no)::before {
    background: rgba(43, 20, 22, 0.12);
  }

  :global(.valentine-note-yes:hover::before),
  :global(.valentine-note-yes:focus-visible::before),
  :global(.valentine-note-no:hover::before),
  :global(.valentine-note-no:focus-visible::before) {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  :global(.valentine-note-no) {
    color: rgba(43, 20, 22, 0.7);
  }

  :global(.valentine-overlay) {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    display: grid;
    place-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    background: #000;
    z-index: 900;
  }

  :global(.valentine-overlay.is-visible) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.valentine-overlay-scrim) {
    position: absolute;
    inset: 0;
    background: #000;
  }

  :global(.valentine-overlay-gif) {
    position: relative;
    width: auto;
    height: auto;
    max-width: 92vw;
    max-height: 92vh;
    object-fit: contain;
    border-radius: 18px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.55);
    z-index: 1;
  }

  :global(.valentine-instructions) {
    position: absolute;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: rgba(244, 243, 242, 0.7);
    pointer-events: none;
    text-align: center;
  }

  @media (max-width: 720px) {
    :global(.valentine-envelope) {
      height: 100vh;
    }

    :global(.valentine-note) {
      font-size: 1.2rem;
    }
  }
</style>
